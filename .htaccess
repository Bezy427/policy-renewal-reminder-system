Options -Indexes

# Deny access to uploads directory except via PHP download handler
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block direct access to uploads
    RewriteRule ^uploads/ - [F,L]

    # Block access to config and class files
    RewriteRule ^config/ - [F,L]
    RewriteRule ^models/ - [F,L]
    RewriteRule ^services/ - [F,L]
    RewriteRule ^controllers/ - [F,L]
    RewriteRule ^views/ - [F,L]
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# PHP settings (if allowed)
<IfModule mod_php.c>
    php_value upload_max_filesize 10M
    php_value post_max_size 12M
    php_flag display_errors Off
</IfModule>
